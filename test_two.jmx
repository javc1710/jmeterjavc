<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>

    <TestPlan testname="Moodle Load Test" enabled="true"/>
    <hashTree>

      <ThreadGroup testname="Usuarios" enabled="true">
        <stringProp name="ThreadGroup.num_threads">${__P(users,5)}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${__P(ramp,30)}</stringProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
      </ThreadGroup>

      <hashTree>

        <!-- CSV -->
        <CSVDataSet testname="Usuarios CSV" enabled="true">
          <stringProp name="filename">/opt/jmeter/tests/usuarios.csv</stringProp>
          <stringProp name="variableNames">username,password</stringProp>
          <boolProp name="ignoreFirstLine">true</boolProp>
          <boolProp name="recycle">true</boolProp>
          <boolProp name="stopThread">false</boolProp>
        </CSVDataSet>
        <hashTree/>

        <!-- Cookies -->
        <CookieManager testname="Cookies" enabled="true"/>
        <hashTree/>

        <!-- LOGIN PAGE -->
        <HTTPSamplerProxy testname="GET Login">
          <stringProp name="HTTPSampler.domain">learningjavc.xyz</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/especiales/login/index.php</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- LOGIN -->
        <HTTPSamplerProxy testname="POST Login">
          <stringProp name="HTTPSampler.domain">learningjavc.xyz</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/especiales/login/index.php</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>

          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">

              <elementProp name="username" elementType="HTTPArgument">
                <stringProp name="Argument.value">${username}</stringProp>
              </elementProp>

              <elementProp name="password" elementType="HTTPArgument">
                <stringProp name="Argument.value">${password}</stringProp>
              </elementProp>

            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- VER QUIZ -->
        <HTTPSamplerProxy testname="Ver Quiz">
          <stringProp name="HTTPSampler.domain">learningjavc.xyz</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/especiales/mod/quiz/view.php?id=1</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- START ATTEMPT -->
        <HTTPSamplerProxy testname="Iniciar intento">
          <stringProp name="HTTPSampler.domain">learningjavc.xyz</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/especiales/mod/quiz/startattempt.php</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- THINK TIME -->
        <ConstantTimer testname="Think Time">
          <stringProp name="ConstantTimer.delay">3000</stringProp>
        </ConstantTimer>
        <hashTree/>

        <!-- FINALIZAR -->
        <HTTPSamplerProxy testname="Finalizar intento">
          <stringProp name="HTTPSampler.domain">learningjavc.xyz</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/especiales/mod/quiz/processattempt.php</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>

          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments">

              <elementProp name="finishattempt" elementType="HTTPArgument">
                <stringProp name="Argument.value">1</stringProp>
              </elementProp>

              <elementProp name="cmid" elementType="HTTPArgument">
                <stringProp name="Argument.value">1</stringProp>
              </elementProp>

            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree/>

      </hashTree>
    </hashTree>
  </hashTree>
</jmeterTestPlan>